# Decision Agent environment template — copy to .env for local non-docker runs.

DA_DB_HOST=localhost
DA_DB_PORT=2346
DA_DB_NAME=decision_db
DA_DB_USER=decision_agent_role
DA_DB_PASSWORD=dev_decision_pw
DA_DB_POOL_MIN=2
DA_DB_POOL_MAX=10

DA_POLL_INTERVAL_SEC=5
DA_BATCH_SIZE=100
DA_ROLE_REFRESH_SEC=300

DA_ADMIN_HOST=0.0.0.0
DA_ADMIN_PORT=9107
DA_ADMIN_STUCK_AFTER_SEC=300

DA_LOG_LEVEL=INFO
DA_LOG_FORMAT=json
