# PoolerTran environment template — copy to .env for local non-docker runs.

# gateway_db (SocketDaim 공용 저장소, cctv_forwarder 롤)
PT_GW_DB_HOST=localhost
PT_GW_DB_PORT=2345
PT_GW_DB_NAME=gateway_db
PT_GW_DB_USER=cctv_forwarder
PT_GW_DB_PASSWORD=dev_forwarder_pw

# decision_db (결과 적재 — 배치 REST 결과를 decision_record 로 기록; detector 롤 재사용)
# 포이즌 메시지(재시도 초과)는 decision_db.transfer_dlq 로 격리.
# decision_db 스키마는 decision_agent/init_db.sql 이 생성한다.
PT_DECISION_DB_HOST=localhost
PT_DECISION_DB_PORT=5432
PT_DECISION_DB_NAME=decision_db
PT_DECISION_DB_USER=sensor_analysis_role
PT_DECISION_DB_PASSWORD=dev_sensor_pw

# REST 전송 대상
PT_REST_URL=http://localhost:8000/ingest
PT_REST_TIMEOUT_SEC=10
# 전송 contract: batch_paths (waypoint 단위 배치 → decision_record; 현재 단독 지원)
PT_REST_MODE=batch_paths
# 데모(더미) 응답 모드 — 실제 REST API 미구현 시 true.  HTTP 호출 없이
# [{score,path1,path2}(정적), {score,path1,path2}(동적)] 더미 응답 반환.
# 실제 API 가동 시 false 로만 바꾸면 됨.  ⚠️ 운영에서는 반드시 false.
PT_REST_DEMO=false
PT_REST_DEMO_SCORE=0.5
# 비우면 입력 프레임의 file_path 를 image_path 로 echo
PT_REST_DEMO_IMAGE_PATH=

# 폴링 / 배치 / 재시도
PT_POLL_INTERVAL_SEC=5
PT_BATCH_SIZE=100
PT_MAX_ATTEMPTS=10
PT_USE_LISTEN=false
# waypoint 전환 감지 초기 sentinel (실제 미사용 waypoint_id). 예: -1 또는 9999
PT_INIT_WAYPOINT_ID=-1
# 큐 정리: 기동 시 전체 삭제(단일 인스턴스 전제), 오래된 행 정리 임계(초, 0=비활성)
# ⚠️ MAX_AGE 는 한 waypoint 체류 최대시간보다 충분히 커야 함(기본 6시간)
PT_CLEAR_QUEUE_ON_START=true
PT_QUEUE_MAX_AGE_SEC=21600

# Health
PT_HEALTH_HOST=0.0.0.0
PT_HEALTH_PORT=9109

PT_LOG_LEVEL=INFO
PT_LOG_FORMAT=json
